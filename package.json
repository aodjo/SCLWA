{
  "name": "sclwa",
  "version": "0.1.0",
  "description": "Study C Language with AI",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm run build:main && concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5800 && cross-env NODE_ENV=development electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:main && vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.2.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/xterm": "^6.0.0",
    "dockerode": "^4.0.9",
    "i18next": "^25.8.13",
    "openai": "^6.25.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.4",
    "react-icons": "^5.5.0",
    "react-resizable-panels": "^4.7.0",
    "sql.js": "^1.14.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}
