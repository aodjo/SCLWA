{
  "name": "c-tutor",
  "version": "1.0.0",
  "description": "Interactive C language learning CLI app with Codex AI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "c-tutor": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "web": "tsx src/web/server.ts",
    "web:api": "tsx src/web/server.ts",
    "web:client": "vite --config webapp/vite.config.ts",
    "web:dev": "concurrently \"npm run web:api\" \"npm run web:client\"",
    "web:build": "vite build --config webapp/vite.config.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aodjo/SCLWA.git"
  },
  "keywords": [
    "c",
    "learning",
    "cli",
    "codex",
    "ai",
    "tutor"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.43.0",
    "chalk": "^5.3.0",
    "ink": "^4.4.1",
    "ink-select-input": "^5.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^5.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/ws": "^8.5.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.14"
  }
}
